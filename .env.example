# ============================================
# Mairomachi 鐜鍙橀噺妯℃澘
# ============================================
# 澶嶅埗鏈枃浠朵负 .env锛堢敓浜э級鎴?.env.development锛堝紑鍙戯級
# 鐒跺悗濉叆浣犺嚜宸辩殑鍚庣鍦板潃鍗冲彲寮€濮嬪紑鍙戙€?
# --------------------------------------------
# 鍚庣鏈嶅姟 Base URL
# --------------------------------------------
# 浣犵殑鍚庣鏈嶅姟鏍瑰湴鍧€銆?
# 寮€鍙戞椂寤鸿鐢ㄦ湰鍦版湇鍔★紱鐢熶骇鏃舵寚鍚戜綘鐨勬湇鍔″櫒銆?
# 璺緞鍓嶇紑锛堝 /api/v1锛夊彇鍐充簬浣犺嚜宸辩殑鍚庣璺敱璁捐锛?
# 鍙淇濊瘉涓嬮潰鐨勭鐐硅矾寰勮兘姝ｇ‘璺敱鍗冲彲銆?
VITE_MAIRO_API_BASE_URL=http://localhost:9090/api/v1
# --------------------------------------------
# 鍚庣 API 绔偣璺緞
# --------------------------------------------
# 浠ヤ笅绔偣鏄墠绔繍琛屾椂瀹為檯璋冪敤鐨勮矾寰勶紝鍧囦负鐩稿璺緞锛?
# 浼氳嚜鍔ㄦ嫾鎺ュ湪 VITE_MAIRO_API_BASE_URL 涔嬪悗銆?
#
# 濡傛灉浣犺嚜琛屽疄鐜板悗绔紝鍙渶淇濊瘉杩欎簺绔偣鎺ュ彈/杩斿洖姝ｇ‘鐨?
# 鏁版嵁缁撴瀯锛堢被鍨嬪畾涔夎 src/main/type/http.ts锛夛紝
# 鍗冲彲涓庡墠绔畬鍏ㄥ吋瀹广€?
# 瀵瑰眬淇℃伅鏌ヨ 鈥?POST
# Request:  ArenaInfoRequest  鈫?Response: ArenaInfoResponse
VITE_API_ENDPOINT_ARENA=/app/arena
# 璁惧婵€娲?鈥?POST锛堟棤闇€ JWT锛岄渶鎵嬪姩浼犲叆 Ed25519 绛惧悕澶达級
# Request:  ActivateRequest   鈫?Response: TokenResponse
VITE_API_ENDPOINT_AUTH_ACTIVATE=/auth/activate
# 璁惧鐧诲綍 鈥?POST锛堟棤闇€ JWT锛岄渶鎵嬪姩浼犲叆 Ed25519 绛惧悕澶达級
# Request:  LoginRequest      鈫?Response: TokenResponse
VITE_API_ENDPOINT_AUTH_LOGIN=/auth/login
# Token 鍒锋柊 鈥?POST锛堥渶鎼哄甫鏃?JWT锛?
# Response: TokenResponse
VITE_API_ENDPOINT_AUTH_REFRESH=/auth/refresh
# 鏈€鏂扮増鏈煡璇?鈥?GET
# Response: CheckUpdateResult
VITE_API_ENDPOINT_VERSION_LATEST=/app/version/latest
# 瀹夎鍖呬笅杞?鈥?GET锛堟祦寮忓搷搴旓級
# 杩斿洖 application/octet-stream
VITE_API_ENDPOINT_DOWNLOAD_LATEST=/app/download/latest
# 鑸拌埞淇℃伅鏌ヨ 鈥?GET
# Response: FileShipInfo
VITE_API_ENDPOINT_INFO_SHIPS=/info/ships
# 鑸拌埞淇℃伅鐗堟湰鏌ヨ 鈥?GET
# 鐢ㄤ簬鍒ゆ柇鏈湴缂撳瓨鏄惁闇€瑕佹洿鏂?
VITE_API_ENDPOINT_INFO_SHIPS_VERSION=/info/ships/version

# 地图信息查询 — GET
# Response: FileMapInfo
VITE_API_ENDPOINT_INFO_MAPS=/info/maps
# 地图信息版本查询 — GET
# 用于判断本地缓存是否需要更新
VITE_API_ENDPOINT_INFO_MAPS_VERSION=/info/maps/version
# 瀵瑰眬璁板綍璇︽儏鏌ヨ 鈥?POST
# Request:  RecordDetailRequest       鈫?Response: RecordDetailPlayerResponse[]
# 琛ュ厖鐜╁ PR銆佷激瀹崇瓑绾с€佸嚮鏉€绛夌骇绛夌粺璁′俊鎭?
VITE_API_ENDPOINT_RECORD_DETAIL=/app/record/detail
# 瀵瑰眬璁板綍缁熻鏌ヨ 鈥?POST锛堟棫鎺ュ彛锛屼繚鐣欏吋瀹癸級
# Request:  { records: RecordStatsItem[] } 鈫?Response: RecordStatsResponse
VITE_API_ENDPOINT_RECORD_STATS=/app/record/stats
# 瀵瑰眬璁板綍缁熻鏌ヨ 鈥?POST锛圧ecordController 鏂版帴鍙ｏ級
# Request:  { records: RecordStatsItem[] } 鈫?Response: RecordStatsResponse
# 璁＄畻鑳滅巼銆佸満鍧囦激瀹炽€佹暣浣?PR 鍙婂搴旈鑹茬瓑绾?
VITE_API_ENDPOINT_RECORD_STATS_NEW=/record/stats
# 瀵瑰眬璁板綍鎵归噺缁熻鏌ヨ 鈥?POST锛圧ecordController 鏂版帴鍙ｏ級
# Request:  List<RecordStatsRequest> 鈫?Response: List<RecordStatsResponse>
# 鎸夊ぉ鍒嗙粍鐨勬壒閲?stats 璁＄畻锛岀敤浜庤秼鍔挎姌绾垮浘
VITE_API_ENDPOINT_RECORD_STATS_BATCH=/record/stats/batch
# 瀵瑰眬璁板綍鎵归噺璇勪及 鈥?POST锛堟棫鎺ュ彛锛屼繚鐣欏吋瀹癸級
# Request:  RecordBatchPrItem[]       鈫?Response: RecordBatchPrResponse[]
VITE_API_ENDPOINT_RECORD_EVALUATE=/app/record/evaluate
# 瀵瑰眬璁板綍鍏細淇℃伅鏌ヨ 鈥?POST锛堟棫鎺ュ彛锛屼繚鐣欏吋瀹癸級
# Request:  RecordClanInfoRequest     鈫?Response: RecordClanInfoResponse[]
# 鎵归噺鑾峰彇鐜╁鎵€灞炲叕浼氫俊鎭紙鍚嶇О銆佹爣绛俱€佸浘鏍囷級
VITE_API_ENDPOINT_RECORD_CLAN_INFO=/app/record/clan-info
# 鍗曞満瀵瑰眬涓€绔欏紡 enrich 鈥?POST锛圧ecordController 鏂版帴鍙ｏ級
# Request:  RecordEnrichBattleRequest 鈫?Response: RecordEnrichBattleResponse
# 涓茶璁＄畻 PR/绛夌骇 + 鏌ヨ鍏細淇℃伅锛屽墠绔寜 accountId 鍚堝苟鍒?players
VITE_API_ENDPOINT_RECORD_BATTLE_ENRICH=/record/battle/enrich
