# ============================================
# Mairomachi 环境变量模板
# ============================================
# 复制本文件为 .env（生产）或 .env.development（开发）
# 然后填入你自己的后端地址即可开始开发。
# --------------------------------------------
# 后端服务 Base URL
# --------------------------------------------
# 你的后端服务根地址。
# 开发时建议用本地服务；生产时指向你的服务器。
# 路径前缀（如 /api/v1）取决于你自己的后端路由设计，
# 只要保证下面的端点路径能正确路由即可。
VITE_MAIRO_API_BASE_URL=http://localhost:9090/api/v1
# --------------------------------------------
# 后端 API 端点路径
# --------------------------------------------
# 以下端点是前端运行时实际调用的路径，均为相对路径，
# 会自动拼接在 VITE_MAIRO_API_BASE_URL 之后。
#
# 如果你自行实现后端，只需保证这些端点接受/返回正确的
# 数据结构（类型定义见 src/main/type/http.ts），
# 即可与前端完全兼容。
# 对局信息查询 — POST
# Request:  ArenaInfoRequest  → Response: ArenaInfoResponse
VITE_API_ENDPOINT_ARENA=/app/arena
# 设备激活 — POST（无需 JWT，需手动传入 Ed25519 签名头）
# Request:  ActivateRequest   → Response: TokenResponse
VITE_API_ENDPOINT_AUTH_ACTIVATE=/auth/activate
# 设备登录 — POST（无需 JWT，需手动传入 Ed25519 签名头）
# Request:  LoginRequest      → Response: TokenResponse
VITE_API_ENDPOINT_AUTH_LOGIN=/auth/login
# Token 刷新 — POST（需携带旧 JWT）
# Response: TokenResponse
VITE_API_ENDPOINT_AUTH_REFRESH=/auth/refresh
# 最新版本查询 — GET
# Response: CheckUpdateResult
VITE_API_ENDPOINT_VERSION_LATEST=/app/version/latest
# 安装包下载 — GET（流式响应）
# 返回 application/octet-stream
VITE_API_ENDPOINT_DOWNLOAD_LATEST=/app/download/latest
# 舰船信息查询 — GET
# Response: FileShipInfo
VITE_API_ENDPOINT_INFO_SHIPS=/info/ships
# 舰船信息版本查询 — GET
# 用于判断本地缓存是否需要更新
VITE_API_ENDPOINT_INFO_SHIPS_VERSION=/info/ships/version
# 对局记录详情查询 — POST
# Request:  RecordDetailRequest       → Response: RecordDetailPlayerResponse[]
# 补充玩家 PR、伤害等级、击杀等级等统计信息
VITE_API_ENDPOINT_RECORD_DETAIL=/app/record/detail
# 对局记录统计查询 — POST
# Request:  { records: RecordStatsItem[] } → Response: RecordStatsResponse
# 计算胜率、场均伤害、整体 PR 及对应颜色等级
VITE_API_ENDPOINT_RECORD_STATS=/app/record/stats
# 对局记录批量评估 — POST
# Request:  RecordBatchPrItem[]       → Response: RecordBatchPrResponse[]
# 批量计算多条记录的 PR、伤害等级、击杀等级、经验等级
VITE_API_ENDPOINT_RECORD_EVALUATE=/app/record/evaluate
# 对局记录公会信息查询 — POST
# Request:  RecordClanInfoRequest     → Response: RecordClanInfoResponse[]
# 批量获取玩家所属公会信息（名称、标签、图标）
VITE_API_ENDPOINT_RECORD_CLAN_INFO=/app/record/clan-info
